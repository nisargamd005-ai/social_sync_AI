# SocialSync AI — Environment Variables
# Copy this file to .env and fill in your real credentials
# Never commit the real .env to version control!

# ── Django ──────────────────────────────────────────────
DJANGO_SECRET_KEY=your-django-secret-key-here
DEBUG=True

# ── Redis (Celery Broker) ────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Telegram ─────────────────────────────────────────────
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ── LinkedIn ─────────────────────────────────────────────
# Create an app at https://developer.linkedin.com
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_PERSON_ID=your-linkedin-person-urn-id

# ── Instagram (Graph API) ────────────────────────────────
# From Meta for Developers: https://developers.facebook.com
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
INSTAGRAM_ACCOUNT_ID=your-instagram-account-id

# ── Twitter / X API v2 ───────────────────────────────────
# Create an app at https://developer.twitter.com
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-twitter-access-token-secret
